NODE_ENV=development
PORT=5000
# Recommended: paste your free MongoDB Atlas connection string here (see README "Database setup").
# It looks like: mongodb+srv://user:pass@cluster.mongodb.net/hunters-ledger
# Alternative (may not work on locked-down networks/corporate laptops - see README): leave as
# "memory" to try a temporary in-memory database with no setup. Data resets on every restart.
MONGO_URI=memory
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_URL=http://localhost:5173
# Optional - only needed if you want "Sign in with Google". See README "Google Sign-In setup".
GOOGLE_CLIENT_ID=
