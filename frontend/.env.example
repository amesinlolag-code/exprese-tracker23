# Only needed when deploying — leave this file unused for local dev (Vite's proxy handles it).
# Set this in Vercel's Project Settings -> Environment Variables to your deployed backend's URL:
VITE_API_URL=https://your-backend.onrender.com/api

# Optional - only needed for "Sign in with Google". Same Client ID as the backend's
# GOOGLE_CLIENT_ID. See README "Google Sign-In setup".
VITE_GOOGLE_CLIENT_ID=
